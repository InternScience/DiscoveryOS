{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DiscoveryOS",
  "version": "0.2.0",
  "identifier": "com.internscience.discoveryos",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "",
    "devUrl": "http://localhost:3000",
    "frontendDist": "http://127.0.0.1:38495"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "DiscoveryOS",
        "url": "http://127.0.0.1:38495",
        "width": 1440,
        "height": 960,
        "minWidth": 1080,
        "minHeight": 720,
        "visible": false,
        "resizable": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/icon.png"
    ],
    "targets": ["deb"],
    "externalBin": [
      "binaries/node"
    ],
    "resources": [
      "resources/next-standalone/**/*"
    ],
    "linux": {
      "appimage": {
        "bundleMediaFramework": false
      },
      "deb": {
        "depends": ["libgtk-3-0", "libwebkit2gtk-4.1-0", "libayatana-appindicator3-1"]
      }
    },
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      }
    }
  }
}
